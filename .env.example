VITE_CONTACT_API_URL=/api/contact
CONTACT_SERVER_URL=http://127.0.0.1:8787

PORT=8787
# Optional. Leave empty to allow local loopback origins such as localhost:5173 and localhost:4173.
ALLOWED_ORIGINS=

# Optional. "auto" uses Resend when configured, otherwise it archives submissions locally.
CONTACT_DELIVERY_MODE=auto
CONTACT_STORAGE_FILE=server/data/contact-submissions.ndjson

RESEND_API_KEY=re_xxxxxxxxx
CONTACT_FROM_EMAIL=FORTUNE <onboarding@resend.dev>
CONTACT_TO_EMAIL=info@fortune.com
CONTACT_SUBJECT_PREFIX=[FORTUNE]
